# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate secrets with: openssl rand -hex 32
JWT_SECRET=change_me_use_openssl_rand_hex_32
REFRESH_SECRET=change_me_use_openssl_rand_hex_32

# First-run admin credentials (used only if the users table is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
# Optional — email for the seeded admin account (enables Gravatar avatar)
ADMIN_EMAIL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Port proxy ────────────────────────────────────────────────────────────────
# Use 127.0.0.1 when running natively. Use host.docker.internal inside Docker.
PROXY_HOST=127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Local database path
DB_PATH=./shellport.db

# ── Log streaming ─────────────────────────────────────────────────────────────
# Colon-separated list of directories the SSE log endpoint is allowed to tail
LOG_DIRS=/tmp:/var/log

# ── Shell ─────────────────────────────────────────────────────────────────────
# Default shell for new terminal sessions (auto-detected from $SHELL if empty)
DEFAULT_SHELL=

# ── Claude Code ───────────────────────────────────────────────────────────────
# Absolute path to the claude binary (auto-detected at startup if empty)
CLAUDE_BIN=

# ── OIDC / SSO ────────────────────────────────────────────────────────────────
# Required in development: URL the browser hits for the frontend (Vite dev server).
# The OIDC callback redirect uses this origin so it lands on the correct port.
# Leave blank in production — frontend and API share the same origin.
FRONTEND_URL=http://localhost:5173

# Optional — AES-256-GCM key for encrypting OIDC client secrets at rest.
# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars / 32 bytes)
# If not set, client secrets are stored as plaintext in the database.
OIDC_SECRET_KEY=
